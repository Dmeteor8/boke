# 环境变量示例文件
# 复制此文件为 .env.local 并填入实际值

# 网站基础配置
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_SITE_NAME=企业服务定制

# 联系信息
NEXT_PUBLIC_CONTACT_PHONE=13151488988
NEXT_PUBLIC_CONTACT_EMAIL=mvpm@vip.qq.com

# 邮件服务配置（选择一种）

# 选项 1: Resend (推荐)
# RESEND_API_KEY=your_resend_api_key
# RESEND_FROM_EMAIL=contact@yourdomain.com

# 选项 2: Nodemailer (SMTP)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_email@example.com
# SMTP_PASS=your_password
# SMTP_FROM=contact@yourdomain.com

# 分析和监控（可选）
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_BAIDU_ANALYTICS_ID=your_baidu_id

# 开发环境配置
NODE_ENV=development
